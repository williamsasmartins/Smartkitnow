Upper = input.toUpperCase();\r\n    const remaining = [...state.tiles];\r\n    const usedIdx = new Set<number>();\r\n    for (const ch of inputUpper) {\r\n      const idx = remaining.findIndex((t, i) => t === ch && !usedIdx.has(i));\r\n      if (idx !== -1) usedIdx.add(idx);\r\n    }\r\n    return usedIdx;\r\n  })", "is_member_call": false, "source_file": "C:\\Users\\Williams Martins\\Pojetos\\Smartkitnow\\src\\components\\games\\ScrabbleSoloGame.tsx", "source_location": "L337"}, {"caller_nid": "games_scrabblesologame_scrabblesolowidget", "callee": "map", "is_member_call": true, "source_file": "C:\\Users\\Williams Martins\\Pojetos\\Smartkitnow\\src\\components\\games\\ScrabbleSoloGame.tsx", "source_location": "L378"}, {"caller_nid": "games_scrabblesologame_scrabblesolowidget", "callee": "map", "is_member_call": true, "source_file": "C:\\Users\\Williams Martins\\Pojetos\\Smartkitnow\\src\\components\\games\\ScrabbleSoloGame.tsx", "source_location": "L429"}, {"caller_nid": "games_scrabblesologame_scrabblesolowidget", "callee": "map", "is_member_call": true, "source_file": "C:\\Users\\Williams Martins\\Pojetos\\Smartkitnow\\src\\components\\games\\ScrabbleSoloGame.tsx", "source_location": "L445"}, {"caller_nid": "games_scrabblesologame_scrabblesolowidget", "callee": "entries", "is_member_call": true, "source_file": "C:\\Users\\Williams Martins\\Pojetos\\Smartkitnow\\src\\components\\games\\ScrabbleSoloGame.tsx", "source_location": "L445"}]}