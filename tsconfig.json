{
  "files": [],  // Mantido: Nenhum arquivo específico, usa references
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": "src",  // Mudado para 'src' – melhor para aliases como '@' em imports dinâmicos, evita erros de resolve
    "paths": {
      "@/*": ["./*"]  // Ajustado para mapear '@/' diretamente para 'src/*' – corrige "Failed to resolve module specifier"
    },
    "noImplicitAny": false,  // Mantido: Permite any implícito para evitar erros em código legado
    "noUnusedParameters": false,  // Mantido: Ignora params não usados
    "skipLibCheck": true,  // Mantido: Acelera build, ignora checks em libs
    "allowJs": true,  // Mantido: Permite JS no projeto (útil se tiver mixed TS/JS)
    "noUnusedLocals": false,  // Mantido: Ignora locals não usados
    "strictNullChecks": true,  // Mudado para true: Ativa checks para null/undefined – melhora segurança sem quebrar muito, mas se der erros, volte para false
    "target": "ES2020",  // Novo: Alvo moderno para Vite, melhora performance
    "module": "ESNext",  // Novo: Para modules modernos, compatível com Vite
    "moduleResolution": "node",  // Novo: Resolução padrão para Node/Vite
    "allowSyntheticDefaultImports": true  // Novo: Permite default imports de modules sem default, comum em libs
  }
}